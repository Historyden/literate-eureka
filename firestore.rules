rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Concept Validation
    function isValidConcept(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.prerequisites is list && data.prerequisites.size() <= 50 &&
             data.masteryScore is number && data.masteryScore >= 0 && data.masteryScore <= 1 &&
             data.status in ['mastered', 'blocked', 'focus', 'locked'] &&
             data.keys().hasAll(['id', 'title', 'description', 'prerequisites', 'masteryScore', 'status']) &&
             data.keys().size() >= 6;
    }

    // StudyAttempt Validation
    function isValidAttempt(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.conceptId is string && data.conceptId.size() <= 128 &&
             data.problem is string && data.problem.size() <= 5000 &&
             data.solution is string && data.solution.size() <= 5000 &&
             data.isSuccess is bool &&
             data.timestamp is timestamp &&
             data.keys().hasAll(['id', 'conceptId', 'problem', 'solution', 'isSuccess', 'timestamp']) &&
             data.keys().size() >= 6;
    }

    function isValidProfile(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             data.level is number &&
             data.createdAt is timestamp &&
             data.keys().hasAll(['uid', 'username', 'level', 'createdAt']) &&
             data.keys().size() >= 4;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidProfile(incoming());
      allow update: if isSignedIn() && userId == request.auth.uid && isValidProfile(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['username', 'bio', 'avatar', 'expertise', 'level'])
      );
    }

    match /concepts/{conceptId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(conceptId) && isValidConcept(incoming());
      allow update: if isSignedIn() && isValidConcept(incoming()) && (
        // Allow updating mastery and status
        incoming().diff(existing()).affectedKeys().hasAny(['masteryScore', 'status', 'lastReviewed'])
      );
      allow delete: if false; // Concepts are usually managed or admin-only
    }

    match /attempts/{attemptId} {
      allow list: if isSignedIn(); // In a real app, restrict by userId
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidId(attemptId) && isValidAttempt(incoming());
      allow update: if false; // Attempts are immutable records
      allow delete: if false;
    }
  }
}
